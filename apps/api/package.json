{
  "name": "apps-api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "start:worker": "ts-node -r tsconfig-paths/register src/worker/main.ts",
    "start:worker:prod": "node dist/worker/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "docker compose -f ../../docker-compose.yml up -d postgres redis && node scripts/wait-for-postgres.js && node scripts/wait-for-redis.js && jest --config test/jest-e2e.json --runInBand",
    "seed": "ts-node -r tsconfig-paths/register src/seed/seed.ts",
    "benchmark:locking": "docker compose -f ../../docker-compose.yml up -d postgres redis && node scripts/wait-for-postgres.js && node scripts/wait-for-redis.js && ts-node -r tsconfig-paths/register scripts/benchmark-locking.ts"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/typeorm": "^10.0.2",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.11.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.15",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
